# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# HERMES Agent Wallet (testnet only, no real funds)
PRIVATE_KEY=0x...

# Deployed Contract Addresses (auto-filled from deployments/arc-testnet.json)
VAULT_ADDRESS=0x...
PERP_ENGINE_ADDRESS=0x...
ORACLE_ADDRESS=0x...

# Strategy: APOLLO | ATLAS | ARES
HERMES_STRATEGY=ATLAS

# Oracle mode: chainlink | mock
ORACLE_MODE=mock

# Polling interval in seconds (default: 15)
CYCLE_INTERVAL=15

# Database path for SQLite decision log
DB_PATH=./data/decisions.db

# API server port (default: 3001)
API_PORT=3001
